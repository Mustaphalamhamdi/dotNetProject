@model GestionProject.Application.DTOs.CreateSoutenanceDto

@{
    ViewData["Title"] = "Planifier une Soutenance";
}

<h1>Planifier une Soutenance</h1>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="Date" class="form-label"></label>
                <input asp-for="Date" class="form-control" type="datetime-local" />
                <span asp-validation-for="Date" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Lieu" class="form-label"></label>
                <input asp-for="Lieu" class="form-control" />
                <span asp-validation-for="Lieu" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="ProjetId" class="form-label">Projet</label>
                <select asp-for="ProjetId" asp-items="ViewBag.Projets" class="form-select">
                    <option value="">-- Sélectionner --</option>
                </select>
            </div>

            <div class="form-group mb-3">
                <label asp-for="MembresJuryIds" class="form-label">Membres du Jury</label>
                <select asp-for="MembresJuryIds" asp-items="ViewBag.MembresJury" class="form-select" multiple></select>
            </div>

            <div class="form-group">
                <input type="submit" value="Planifier" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Annuler</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
