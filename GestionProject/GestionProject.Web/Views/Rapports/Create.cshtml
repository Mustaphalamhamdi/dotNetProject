@model GestionProject.Application.DTOs.CreateRapportDto

@{
    ViewData["Title"] = "Soumettre un Rapport";
}

<h1>Soumettre un Rapport</h1>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="Version" class="form-label"></label>
                <input asp-for="Version" class="form-control" />
                <span asp-validation-for="Version" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="CheminFichier" class="form-label">Chemin du Fichier</label>
                <input asp-for="CheminFichier" class="form-control" />
                <span asp-validation-for="CheminFichier" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="ProjetId" class="form-label">Projet</label>
                <select asp-for="ProjetId" asp-items="ViewBag.Projets" class="form-select">
                    <option value="">-- Sélectionner --</option>
                </select>
                <span asp-validation-for="ProjetId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Soumettre" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Annuler</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
