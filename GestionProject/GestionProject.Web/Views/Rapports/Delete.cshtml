@model GestionProject.Application.DTOs.RapportDto

@{
    ViewData["Title"] = "Supprimer le Rapport";
}

<h1>Confirmer la suppression</h1>
<h3>Êtes-vous sûr de vouloir supprimer ce rapport ?</h3>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Version</dt><dd class="col-sm-9">@Model.Version</dd>
            <dt class="col-sm-3">Projet</dt><dd class="col-sm-9">@Model.ProjetTitre</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <input type="submit" value="Supprimer" class="btn btn-danger" />
    <a asp-action="Index" class="btn btn-secondary">Annuler</a>
</form>
