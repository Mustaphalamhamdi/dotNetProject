@model GestionProject.Application.DTOs.UpdateRapportDto

@{
    ViewData["Title"] = "Modifier le Rapport";
}

<h1>Modifier le Rapport</h1>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />

            <div class="form-group mb-3">
                <label asp-for="Version" class="form-label"></label>
                <input asp-for="Version" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="CheminFichier" class="form-label">Chemin du Fichier</label>
                <input asp-for="CheminFichier" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="ProjetId" class="form-label">Projet</label>
                <select asp-for="ProjetId" asp-items="ViewBag.Projets" class="form-select"></select>
            </div>

            <div class="form-group">
                <input type="submit" value="Enregistrer" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Annuler</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
