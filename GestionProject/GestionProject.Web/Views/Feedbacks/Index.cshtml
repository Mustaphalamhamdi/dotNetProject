@model IEnumerable<GestionProject.Application.DTOs.FeedbackDto>

@{
    ViewData["Title"] = "Feedbacks";
}

<h1>Liste des Feedbacks</h1>

<p><a asp-action="Create" class="btn btn-primary">Ajouter un feedback</a></p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Date</th>
            <th>Encadrant</th>
            <th>Contenu</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Date.ToString("dd/MM/yyyy")</td>
                <td>@item.EncadrantNom</td>
                <td>@(item.Contenu.Length > 100 ? item.Contenu.Substring(0, 100) + "..." : item.Contenu)</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Détails</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Modifier</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Supprimer</a>
                </td>
            </tr>
        }
    </tbody>
</table>
