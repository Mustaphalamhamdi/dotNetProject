@model GestionProject.Application.DTOs.FeedbackDto

@{
    ViewData["Title"] = "Supprimer le Feedback";
}

<h1>Confirmer la suppression</h1>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Date</dt><dd class="col-sm-9">@Model.Date.ToString("dd/MM/yyyy")</dd>
            <dt class="col-sm-3">Encadrant</dt><dd class="col-sm-9">@Model.EncadrantNom</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <input type="submit" value="Supprimer" class="btn btn-danger" />
    <a asp-action="Index" class="btn btn-secondary">Annuler</a>
</form>
