@model GestionProject.Application.DTOs.UpdateSeanceDto

@{
    ViewData["Title"] = "Modifier la Séance";
}

<h1>Modifier la Séance</h1>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />

            <div class="form-group mb-3">
                <label asp-for="Date" class="form-label"></label>
                <input asp-for="Date" class="form-control" type="datetime-local" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="Type" class="form-label"></label>
                <select asp-for="Type" asp-items="ViewBag.Types" class="form-select"></select>
            </div>

            <div class="form-group mb-3">
                <label asp-for="ProjetId" class="form-label">Projet</label>
                <select asp-for="ProjetId" asp-items="ViewBag.Projets" class="form-select"></select>
            </div>

            <div class="form-group mb-3">
                <label asp-for="EncadrantId" class="form-label">Encadrant</label>
                <select asp-for="EncadrantId" asp-items="ViewBag.Encadrants" class="form-select"></select>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Notes" class="form-label"></label>
                <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Commentaires" class="form-label"></label>
                <textarea asp-for="Commentaires" class="form-control" rows="3"></textarea>
            </div>

            <div class="form-group">
                <input type="submit" value="Enregistrer" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Annuler</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
