@model IEnumerable<GestionProject.Application.DTOs.SeanceDto>

@{
    ViewData["Title"] = "Séances";
}

<h1>Liste des Séances</h1>

<p><a asp-action="Create" class="btn btn-primary">Planifier une séance</a></p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Date</th>
            <th>Type</th>
            <th>Projet</th>
            <th>Encadrant</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Date.ToString("dd/MM/yyyy")</td>
                <td>@item.Type</td>
                <td>@item.ProjetTitre</td>
                <td>@item.EncadrantNom</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Détails</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Modifier</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Supprimer</a>
                </td>
            </tr>
        }
    </tbody>
</table>
