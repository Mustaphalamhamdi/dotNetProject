@model GestionProject.Application.DTOs.MembreJuryDto

@{
    ViewData["Title"] = "Supprimer le Membre du Jury";
}

<h1>Confirmer la suppression</h1>
<h3>Êtes-vous sûr de vouloir supprimer ce membre ?</h3>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Nom</dt><dd class="col-sm-9">@Model.Nom</dd>
            <dt class="col-sm-3">Prénom</dt><dd class="col-sm-9">@Model.Prenom</dd>
            <dt class="col-sm-3">Email</dt><dd class="col-sm-9">@Model.Email</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <input type="submit" value="Supprimer" class="btn btn-danger" />
    <a asp-action="Index" class="btn btn-secondary">Annuler</a>
</form>
