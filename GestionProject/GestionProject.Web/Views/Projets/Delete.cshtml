@model GestionProject.Application.DTOs.ProjetDto

@{
    ViewData["Title"] = "Supprimer le Projet";
}

<h1>Confirmer la suppression</h1>

<h3>Êtes-vous sûr de vouloir supprimer ce projet ?</h3>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Titre</dt>
            <dd class="col-sm-9">@Model.Titre</dd>
            <dt class="col-sm-3">Type</dt>
            <dd class="col-sm-9">@Model.Type</dd>
            <dt class="col-sm-3">Statut</dt>
            <dd class="col-sm-9">@Model.Statut</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <input type="submit" value="Supprimer" class="btn btn-danger" />
    <a asp-action="Index" class="btn btn-secondary">Annuler</a>
</form>
