@model GestionProject.Application.DTOs.EvaluationDto

@{
    ViewData["Title"] = "Supprimer l'Évaluation";
}

<h1>Confirmer la suppression</h1>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Note</dt><dd class="col-sm-9">@Model.Note / 20</dd>
            <dt class="col-sm-3">Membre du Jury</dt><dd class="col-sm-9">@Model.MembreJuryNom</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <input type="submit" value="Supprimer" class="btn btn-danger" />
    <a asp-action="Index" class="btn btn-secondary">Annuler</a>
</form>
